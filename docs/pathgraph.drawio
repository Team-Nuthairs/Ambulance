        <mxCell id="QiFT9hzez9o_W1sWfNKu-242" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Not only does a path graph define the shape of a path, it also defines a spline for AI to walk. There is no such thing as a &quot;navmesh&quot; here and pathing is point to point." vertex="1">
          <mxGeometry height="155" width="160" x="420" y="1225" as="geometry" />
        </mxCell>
        <mxCell id="QiFT9hzez9o_W1sWfNKu-243" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="AI will have extra behaviors instead of blindly moving along the path. With simple event logic they can decide to turn, stop at an intersection, pull over for sirens. We can also choose their position in the road so that some drivers will hog the lane or hug the shoulder." vertex="1">
          <mxGeometry height="155" width="220" x="400" y="1390" as="geometry" />
        </mxCell>
