        <mxCell id="dt-6no" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Do not make a road between chunks, new chunk gets demoted. $ way becomes 3 way, 3 way becomes straight/turn, etc" vertex="1">
