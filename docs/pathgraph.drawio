        <mxCell id="QiFT9hzez9o_W1sWfNKu-2" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Path Graph&lt;/h1&gt;&lt;p&gt;A path graph is a set of nodes and edges, Nodes are a point in space. An edge is a connection between nodes&lt;/p&gt;" vertex="1">
          <mxGeometry height="90" width="370" x="10" as="geometry" />
        </mxCell>
        <mxCell id="QiFT9hzez9o_W1sWfNKu-3" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Chunks&lt;/h1&gt;&lt;p&gt;The world is divided into chunks. Chunks will contain either a node or a lot. A lot is where the story events spawn. The chunks will have a data model similar to:&lt;br&gt;&lt;br&gt;chunk.edges = { north: bool, south: bool, east: bool, west: bool }&lt;br&gt;chunk.type   = derived from edge count + pattern&lt;br&gt;chunk.node   = { x, y } offset from chunk center, or null&lt;br&gt;chunk.biome  = &quot;suburb&quot; | &quot;slum&quot; | &quot;downtown&quot; | &quot;lot&quot; | ...&lt;/p&gt;" vertex="1">
          <mxGeometry height="230" width="370" x="10" y="100" as="geometry" />
        </mxCell>
        <mxCell id="QiFT9hzez9o_W1sWfNKu-4" edge="1" parent="1" source="QiFT9hzez9o_W1sWfNKu-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;endArrow=none;endFill=0;" target="QiFT9hzez9o_W1sWfNKu-27">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="QiFT9hzez9o_W1sWfNKu-5" parent="1" style="whiteSpace=wrap;html=1;aspect=fixed;strokeColor=light-dark(#000000,#FFD966);" value="" vertex="1">
          <mxGeometry height="80" width="80" x="120" y="630" as="geometry" />
        </mxCell>
        <mxCell id="QiFT9hzez9o_W1sWfNKu-6" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Story Lots&lt;/h1&gt;&lt;p&gt;Story lots are the name given to the lots generated by the accepted jobs and the garage. This is where we navigate to and from.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;If an event spawns a story lot here is the process of how the path gets procedurally drawn through the city.&amp;nbsp;&lt;/p&gt;" vertex="1">
          <mxGeometry height="230" width="370" x="10" y="300" as="geometry" />
        </mxCell>
