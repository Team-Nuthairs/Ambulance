        <mxCell id="o05vOpjIfVoNKR81GA2A-4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Regardless of how random the road is, the path to the destination can easily be found using simple taxicab geometry. This would trivialize the job of the navigator." vertex="1">
          <mxGeometry height="130" width="160" x="830" y="1175" as="geometry" />
        </mxCell>
