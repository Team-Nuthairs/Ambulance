        </mxCell>
        <mxCell id="dt-9" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" value="Double 3-way detail: chunk splits along an axis. All 4 external edges stay true but two nodes generate inside, joined by one internal edge" vertex="1">
          <mxGeometry height="100" width="200" x="970" y="375" as="geometry" />
        </mxCell>
        <mxCell id="dt-e13" edge="1" parent="1" source="dt-3e" style="endArrow=classic;endFill=1;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.3;" target="dt-9">
