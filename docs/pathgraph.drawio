          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="dt-10" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Neighbors never know it&#39;s split. They only ever see the 4 external booleans, same as any other chunk" vertex="1">
