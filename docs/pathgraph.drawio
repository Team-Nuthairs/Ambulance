            <mxPoint x="1395" y="288.18181818181824" as="sourcePoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="dt-7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Story lot check: did this lot end up with zero active edges after all neighbors resolved?" vertex="1">
          <mxGeometry height="70" width="180" x="385" y="380" as="geometry" />
        </mxCell>
        <mxCell id="dt-8" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" value="Force-promote nearest neighbor edge to true regardless of its current type. This is the failsafe so jobs never become unreachable" vertex="1">
          <mxGeometry height="90" width="180" x="610" y="407.5" as="geometry" />
        </mxCell>
        <mxCell id="dt-e12" edge="1" parent="1" source="dt-7" style="endArrow=classic;endFill=1;html=1;" target="dt-8" value="yes">
